{
  "name": "brev.ly-server",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --env-file-if-exists=.env --watch src/server.ts",
    "build": "tsdown src/server.ts",
    "start": "node --env-file-if-exists=.env dist/server.mjs",
    "test": "vitest",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:seed": "node --env-file-if-exists=.env src/db/scripts/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "ultracite": "7.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
